# Copy to .env and fill in what you need. ALL values are OPTIONAL:
# without any key the agent runs fully offline (rule-based fallback).

# --- LLM provider selection ---
# auto | openai | anthropic | gemini | groq | local
UNIFIED_PROVIDER=auto
UNIFIED_MODEL=
# Custom OpenAI-compatible endpoint (Ollama, vLLM, LM Studio, OpenRouter...)
UNIFIED_BASE_URL=http://localhost:11434/v1

# --- Provider keys (only the one you use) ---
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
GROQ_API_KEY=
# For local/Ollama you usually don't need a key.
OLLAMA_BASE_URL=http://localhost:11434

# --- Optional HTTP API token (empty = API open) ---
UNIFIED_API_TOKEN=

# --- Device tuning ---
# 1 = force weak-device mode (smaller models, reduced features)
# 0 = force full mode
UNIFIED_WEAK_DEVICE=

# --- Telegram bot (optional) ---
UNIFIED_TELEGRAM_TOKEN=
# Comma-separated allowed chat/user ids; empty = allow all
UNIFIED_TELEGRAM_ALLOWED=
